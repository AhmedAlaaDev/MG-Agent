# Copy to .env and fill in real values:  copy .env.example .env

# ── Azure OpenAI (houseblreader-resource) ───────────────────────────────────
# Set LLM_PROVIDER=azure to use Azure instead of Gemini for extraction.
AZURE_OPENAI_ENDPOINT=https://houseblreader-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_KEY_HERE
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_PROJECT_URL=https://houseblreader-resource.services.ai.azure.com/api/projects/houseblreader

# ── OCR ─────────────────────────────────────────────────────────────────────
OCR_DPI=300
TESSERACT_LANG=eng
# Local Windows only (Docker overrides to /usr/bin/tesseract in compose):
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ── Extraction limits ───────────────────────────────────────────────────────
MAX_INPUT_CHARS=90000
NATIVE_MIN_CHARS=600
NATIVE_MIN_FIELD_HITS=5
EXCEL_MAX_ROWS_PER_SHEET=2500
EXCEL_MAX_COLS_PER_SHEET=80
EXCEL_MAX_CELL_CHARS=500
# Gemini reads far longer docs than Azure (900k chars); chunk + merge beyond that.
GEMINI_MAX_INPUT_CHARS=900000
GEMINI_NATIVE_PDF=true
GEMINI_NATIVE_SPREADSHEET=true
GEMINI_WORKBOOK_LLM_MIN_ROWS=3

# ── Dynamics 365 / Dataverse ───────────────────────────────────────────────
TENANT_ID=your-tenant-id
CLIENT_ID=your-app-client-id
CLIENT_SECRET=your-client-secret
BASE_URL=https://your-org.crm4.dynamics.com
AZURE_APP_API_URL=https://your-org.crm4.dynamics.com/api/data/v9.2

# ── Docker host port mapping ────────────────────────────────────────────────
API_PORT=8000

# ── Google Gemini (optional — set LLM_PROVIDER=gemini to use for extraction) ──
# Per-request override: POST /extract/pdf?llm_provider=gemini&llm_model=gemini-3.5-flash
# Model ids match Puter.js free tier (backend uses Google AI API + GEMINI_API_KEY, not Puter.js).
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ── CRM business rules (freight/booking/load type/TEUs/totals) ───────────────
# Set false to disable automatic Prepaid→Freehand/Origin, Collect→Nomination/Destination, etc.
CUSTOM_BUSINESS_RULES_ENABLED=true
